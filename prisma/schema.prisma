generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model TestResult {
  id          String   @id @default(cuid())
  
  testDate    DateTime @default(now())
  
  rootScore       Int
  solarPlexusScore Int
  sacralScore     Int
  heartScore      Int
  throatScore     Int
  thirdEyeScore   Int
  crownScore      Int
  
  answers     Json
  
  deviceId    String
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([deviceId])
  @@index([testDate])
}
